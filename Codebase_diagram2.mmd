graph TB
    subgraph Client["🌐 Client Layer"]
        User["Client Application<br/>(HTTP Requests)"]
    end
    
    subgraph Gateway["🚪 API Gateway"]
        AG["ApiGateway<br/>(YARP Reverse Proxy)<br/>Port 5050"]
    end
    
    subgraph Services["📦 Microservices"]
        subgraph Catalog["Catalog Service"]
            CA["Catalog.API<br/>GET /items"]
            ICR["ICatalogRepository<br/>(Interface)"]
            CR["CatalogRepository<br/>(MongoDB Implementation)"]
            CS["CatalogSyncWorker<br/>(Background Service)"]
        end
        
        subgraph Booking["Booking Service"]
            BA["Booking.API<br/>POST /book/{seatId}"]
            BConfig["Booking Config<br/>Redis + RabbitMQ<br/>DI Setup"]
        end
    end
    
    subgraph Models["📋 Domain Models"]
        CI["CatalogItem<br/>EventName, Price<br/>AvailableSeats"]
        TO["TicketOrder<br/>Id, SeatId<br/>UserId, ProcessedAt<br/>Status"]
        OM["OutboxMessage<br/>Id, EventType<br/>Payload, CreatedOnUtc<br/>ProcessedOnUtc"]
    end
    
    subgraph Workers["⚙️ Background Workers"]
        PW["PaymentProcessor.Worker<br/>(RabbitMQ Consumer)"]
        ORW["OutboxRelayWorker<br/>(Outbox Poller 5s)"]
    end
    
    subgraph DBContext["💾 Database Context"]
        TDC["TicketDbContext<br/>(Entity Framework)<br/>TicketOrders<br/>OutboxMessages"]
    end
    
    subgraph Infra["🏗️ Infrastructure"]
        MongoDB["MongoDB<br/>CatalogDb<br/>Tickets Collection"]
        Redis["Redis<br/>Distributed Locks<br/>seat:lock:{seatId}"]
        RabbitMQ["RabbitMQ<br/>Queue: ticket_orders<br/>Exchange: ticket_events"]
        SqlServer["SQL Server<br/>TicketDb<br/>2 Tables"]
        Seq["Seq<br/>Centralized Logging<br/>Port 8081"]
    end
    
    User -->|HTTP| AG
    AG -->|Route| CA
    AG -->|Route| BA
    
    CA --> ICR
    ICR --> CR
    CR --> MongoDB
    CS --> MongoDB
    
    BA --> BConfig
    BA -->|Lock seat| Redis
    BA -->|Publish| RabbitMQ
    
    RabbitMQ -->|Consume| PW
    PW --> TDC
    TDC --> SqlServer
    
    ORW --> TDC
    ORW -->|Publish events| RabbitMQ
    
    PW -.->|Logs| Seq
    BA -.->|Logs| Seq
    CA -.->|Logs| Seq
    ORW -.->|Logs| Seq
    
    TDC -.->|Models| TO
    TDC -.->|Models| OM
    CR -.->|Model| CI
    
